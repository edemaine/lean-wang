    Figure13PositiveBoardLevelTileableSquares ↔ TilesPlane fig13Tiles :=
  ⟨tilesPlane_fig13Tiles_of_positiveBoardLevelTileableSquares,
    positiveBoardLevelTileableSquares_of_tilesPlane_fig13Tiles⟩

