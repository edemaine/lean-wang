    Figure13CofinalTileableSquares := by
  intro n
  refine ⟨RobinsonSquare.freeGridSide (n + 1), ?_, hsquares n⟩
  exact Nat.le_trans (Nat.le_succ n)
    (RobinsonSquare.self_le_freeGridSide (n + 1))

